{
  // python
  "ruff.lineLength": 88,
  "debugpy.debugJustMyCode": false,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  // shell
  "shellcheck.customArgs": [
    "--shell=bash" // REVIEW: find zsh equivalent tool
  ],
  "shellcheck.exclude": [
    "1071" // allow zsh
  ],
  "[shellscript]": {
    "editor.detectIndentation": false,
    "editor.tabSize": 2
  },
  // file associations
  "files.associations": {
    "**/ghostty/config": "ini",
    "*gitconfig*": "properties",
    "*ssh.config*": "ssh_config",
    "*zshrc*": "shellscript",
    "*zshenv*": "shellscript"
  },
  // spelling
  "cSpell.ignorePaths": [
    ".git",
    ".github",
    ".venv",
    ".vscode",
    ".gitignore",
  ],
  "cSpell.words": [
    "dotenv",
    "Fareed",
    "fpath",
    "GHCS",
    "ghostty",
    "linuxbrew",
    "macbook",
    "mohdfareed",
    "openclaw",
    "pwsh",
    "pydantic",
    "pyright",
    "shellcheck",
    "tailscale",
    "typer",
    "venv",
    "WINGET",
    "wslinfo",
    "zfunc",
    "zinit"
  ]
}
