{
  // # MARK: Editor ===========================================================
  "theme": "One Dark Pro",
  "icon_theme": "Material Icon Theme",
  "format_on_save": "on",
  "show_whitespaces": "all",
  "wrap_guides": [80, 120],
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "ui_font_size": 14,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "option_as_meta": true,
  },
  "git_panel": {
    "tree_view": true,
  },
  // # MARK: Languages ========================================================
  "file_types": {
    "JSONC": ["**/*.json", "**/*.code-snippets"],
  },
  "languages": {
    "Python": {
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
    },
    "Shell Script": {
      "tab_size": 2,
    },
    "JSONC": {
      "tab_size": 2,
    },
    "YAML": {
      "tab_size": 2,
    },
    "Markdown": {
      "tab_size": 2,
    },
    "Plain Text": {
      "language_servers": ["bookmark-language-server"],
    },
  },
  // # MARK: Remote Dev =======================================================
  "ssh_connections": [
    {
      "host": "rpi",
      "projects": [],
    },
    {
      "host": "pc",
      "projects": [],
    },
    {
      "host": "homelab",
      "username": "claudia",
      "projects": [],
    },
  ],
  // # MARK: Agents ===========================================================
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  // # MARK: MCP Servers ======================================================
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "GITHUB_MCP_TOKEN",
      },
    },
    "mem0": {
      "enabled": true,
      "settings": {
        "url": "https://mem0.tail2a477.ts.net/mcp/openmemory/sse/mohdfareed",
      },
    },
    "personal-memories": {
      "enabled": true,
      "settings": {
        "url": "https://kbm.tail2a477.ts.net/personal",
      },
    },
    "work-memories": {
      "enabled": true,
      "settings": {
        "url": "https://kbm.tail2a477.ts.net/work",
      },
    },
  },
}
