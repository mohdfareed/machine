#!/usr/bin/env zsh

# paths
export PATH="$DEV/bin:$PATH" # local binaries

# profile a command with gnu time
function profile {
    usage="usage: $0 command [args...]"
    if (($# < 1)); then echo "$usage" && return 1; fi

    format="\
    ===Profiling Report===
    ===Real time:    %es
    ===Memory usage: %MKB
    ===File size:    $(du -sh "$(which "$1")" | cut -f1)"
    gtime -f "$format" "$@"
}
