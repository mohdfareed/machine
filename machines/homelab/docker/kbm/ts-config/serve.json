{
  "TCP": {
    "443": {
      "HTTPS": true,
    },
  },
  "Web": {
    "${TS_CERT_DOMAIN}:443": {
      "Handlers": {
        "/personal": {
          "Proxy": "http://127.0.0.1:3001/personal",
        },
        "/work": {
          "Proxy": "http://127.0.0.1:3002/work",
        },
      },
    },
  },
  "AllowFunnel": {
    "${TS_CERT_DOMAIN}:443": true,
  },
}
