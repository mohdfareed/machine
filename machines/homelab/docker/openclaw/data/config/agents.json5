// Agents — workspace and behavior
{
  "defaults": {
    "model": {
      "primary": "anthropic/claude-opus-4-6",
      "fallbacks": [
        "anthropic/claude-sonnet-4-6",
        "openai-codex/gpt-5.3-codex",
        "openai/gpt-5.2",
        "google/gemini-3.1-pro",
        "google/gemini-3-flash",

      ],
    },
    "workspace": "/home/node/.openclaw/workspace",
    "contextPruning": {
      "mode": "cache-ttl",
      "ttl": "1h"
    },
    "compaction": {
      "mode": "safeguard"
    },
    "heartbeat": {
      "every": "30m"
    }
  }
}
