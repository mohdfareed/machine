// Plugins — extensions and memory
{
  "enabled": true,

  // Keep ONE memory provider active.
  "slots": { "memory": "openclaw-mem0" },

  "entries": {
    "telegram": { "enabled": true },
    "device-pair": { "enabled": true },
    "llm-task": { "enabled": true },
    "lobster": { "enabled": true },

    // Memory slot companions (disabled because slot is owned by mem0)
    "memory-core": { "enabled": false },
    "memory-lancedb": { "enabled": false },

    // Mem0 memory plugin
    "openclaw-mem0": {
      "enabled": true,
      "config": {
        "mode": "open-source",
        "userId": "${MEM0_USER_ID}",
      }
    },

    "voice-call": {
      "enabled": true,
      "config": {
        "enabled": true,
        "streaming": { "enabled": true },
        "tts": { "enabled": true, "mode": "all" }
      }
    }
  }
}
