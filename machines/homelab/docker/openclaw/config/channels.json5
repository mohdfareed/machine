// Channel — agent messaging
{
  // Telegram channel — webhook mode via Tailscale Funnel
  telegram: {
    enabled: true,
    botToken: "${TELEGRAM_BOT_TOKEN}",
    dmPolicy: "pairing",
    groups: { "*": { requireMention: true } },
    streamMode: "partial",
    actions: {
      reactions: true,
      sendMessage: true,
      deleteMessage: true,
      sticker: true,
    },

    // Webhook mode — Tailscale Funnel exposes port 8443 publicly.
    // Traefik strips /openclaw before forwarding, so OpenClaw sees /telegram.
    // Set TELEGRAM_WEBHOOK_URL to https://<hostname>.<tailnet>.ts.net:8443/openclaw/telegram
    webhookUrl: "${TELEGRAM_WEBHOOK_URL}",
    webhookSecret: "${TELEGRAM_WEBHOOK_SECRET}",
    webhookPath: "/telegram",
  },
}
