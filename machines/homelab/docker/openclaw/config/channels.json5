// Channel — agent messaging
{
  // Telegram channel — webhook mode via Tailscale Funnel
  telegram: {
    enabled: true,
    botToken: "${TELEGRAM_BOT_TOKEN}",
    dmPolicy: "pairing",
    groups: { "*": { requireMention: true } },
    streamMode: "partial",
    actions: {
      sendMessage: true,
      deleteMessage: true,
      reactions: true,
      sticker: true,
    },

    // Webhook mode — Tailscale Funnel exposes port 443 publicly.
    // REVIEW: Disabled due to unknown conflict on port 8787 in container.
    // webhookUrl: "${TELEGRAM_WEBHOOK_URL}",
    // webhookSecret: "${TELEGRAM_WEBHOOK_SECRET}",
  },
}
