// OpenClaw Gateway — Homelab Server
// Secrets use ${VAR} env substitution from process environment.
// Config split via $include: channels, skills, plugins.
{
  "gateway": {
    "bind": "lan", // container port mapping
    "auth": { "allowTailscale": true }
  },
  "agents": {
    "$include": "./config/agents.json5"
  },
  "channels": {
    "$include": "./config/channels.json5"
  },
  "hooks": {
    "$include": "./config/hooks.json5"
  },
  "plugins": {
    "$include": "./config/plugins.json5"
  },
  "skills": {
    "$include": "./config/skills.json5"
  },
  "tools": {
    "$include": "./config/tools.json5"
  }
}
