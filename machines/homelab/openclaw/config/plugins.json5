// Plugins - extensions and memory
{
  "enabled": true,
  "allow": [
    "telegram",
    "device-pair",
    "llm-task",
    "lobster",
    "memory-lancedb",
    "acpx"
  ],

  // Keep ONE memory provider active.
  "slots": { "memory": "memory-lancedb" },

  "entries": {
    "telegram": { "enabled": true },
    "device-pair": { "enabled": true },
    "llm-task": { "enabled": true },
    "lobster": { "enabled": true },

    // Memory slot companions
    "memory-core": { "enabled": false },
    "memory-lancedb": {
      "enabled": true,
      "config": {
        "autoCapture": true,
        "autoRecall": true,
        "embedding": {
          "apiKey": "${OPENAI_API_KEY}",
        }
      }
    },

    "acpx": { "enabled": true }
  }
}
