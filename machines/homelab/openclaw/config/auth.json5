// Authentication - model provider credentials
{
  "profiles": {
    "github-copilot:default": {
      "provider": "github-copilot",
      "mode": "token"
    },
    "openai-codex:default": {
      "provider": "openai-codex",
      "mode": "oauth"
    },
    "openai:default": {
      "provider": "openai",
      "mode": "token"
    },
    "anthropic:default": {
      "provider": "anthropic",
      "mode": "token"
    },
    "google:default": {
      "provider": "google",
      "mode": "token"
    },
  }
}
