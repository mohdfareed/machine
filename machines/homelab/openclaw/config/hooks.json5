// Hooks - agent event hooks
{
  "enabled": true,
  "token": "${OPENCLAW_HOOKS_TOKEN}",
  "defaultSessionKey": "hook:ingress",
  "allowRequestSessionKey": false,
  "allowedSessionKeyPrefixes": ["hook:"],
  "internal": {
    "enabled": true,
    "entries": {
      "boot-md": {
        "enabled": true
      },
      "command-logger": {
        "enabled": true
      },
      "session-memory": {
        "enabled": true
      },
      "bootstrap-extra-files": {
        "enabled": true,
      },
    }
  }
}
