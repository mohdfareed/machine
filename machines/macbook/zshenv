#!/usr/bin/env zsh

# Machine environment (generated by mc setup)
[[ -f "$HOME/.config/mc/env" ]] && source "$HOME/.config/mc/env"

# Source shared environment
source "${MC_HOME:-$HOME/.machine}/config/shell/zshenv"

# Machine-specific environment
export DEV="$HOME/Developer"
export PATH="$DEV/bin:$PATH" # local binaries
export ICLOUD="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
export GODOT="/Applications/Godot_mono.app/Contents/MacOS/Godot"
