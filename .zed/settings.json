{
  "context_servers": {
    "machine-memories": {
      "command": "kbm",
      "args": ["start", "machine"],
    },
  },
  "file_types": {
    "JSONC": [
      "**/zed/settings.json",
      "**/vscode/settings.json",
      "**/*.code-snippets",
    ],
    "JSON5": ["**/openclaw.json"],
    "ini": ["**/ghostty/config", "**/ssh.config"],
    "Git Config": ["**/.gitconfig.*"],
    "Shell Script": ["**/.zshenv.*", "**/.zshrc.*"],
  },
}
