{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  // Built-in dictionaries cover most technical terms for these languages.
  // Only add to `words` what they genuinely miss.
  "dictionaries": [
    "bash",
    "powershell",
    "python",
    "softwareTerms",
    "companies"
  ],
  "ignorePaths": [
    "*.lock",
    "machines/**/openclaw/workspace/**",
    "machines/**/openclaw/cron/**"
  ],
  "words": [
    "Eeuo",
    "cmux",
    "Dockge",
    "dotenv",
    "elevenlabs",
    "fareed",
    "fpath",
    "GHCS",
    "ghostty",
    "homelab",
    "hostnames",
    "linuxbrew",
    "macbook",
    "mohdfareed",
    "mohds",
    "openclaw",
    "pwsh",
    "pydantic",
    "pyright",
    "shellcheck",
    "tailnet",
    "tailscale",
    "typer",
    "venv",
    "winget",
    "wslinfo",
    "zfunc",
    "zinit",
    "keepalive",
    "chatmock",
    "distros",
    "LASTEXITCODE",
    "distors",
    "VIRTUALENV",
    "SAVEHIST",
    "HISTDUP",
    "shellenv",
    "libexec",
    "freethreading",
    "dups",
    "appendhistory",
    "sharehistory",
    "atinit",
    "zicompinit",
    "zicdreplay",
    "zdharma",
    "blockf",
    "atload",
    "Aloxaf",
    "btop",
    "Dobbeleer",
    "gsserver",
    "winerror",
    "hardlink",
    "mklink",
    "pathlib",
    "pycache",
    "pytest",
    "ericc",
    "openmemory",
    "qdrant",
    "gethomepage",
    "AUTHKEY",
    "USERSPACE",
    "healthcheck",
    "quicklaunch"
  ]
}
