{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,

  // Built-in dictionaries cover most technical terms for these languages.
  // Only add to `words` what they genuinely miss.
  "dictionaries": ["bash", "powershell", "python", "softwareTerms", "companies"],

  "ignorePaths": [
    "*.lock",
    "machines/**/machine.env",
    "machines/**/manifest.py",
    // Free-form AI agent content — proper names, jargon, invented words
    "machines/**/openclaw/workspace/**",
    // Runtime state — error messages, command strings, timestamps
    "machines/**/openclaw/cron/**"
  ],

  "words": [
    // People & usernames
    "Aloxaf", "charliermarsh", "Dobbeleer", "donjayamanne", "Duffield",
    "ericc", "fareed", "mohdfareed", "mohds", "timonwong", "yzhang",

    // Project & system names
    "acpx", "chatmock", "clawhub", "cmux", "Dockge", "elevenlabs", "fastmcp", 
    "gethomepage", "ghostty", "greptile", "homelab", "lancedb", "macbook", 
    "mcporter", "openclaw", "openmemory", "qdrant", "tailnet", "tailscale", 
    "tskey", "webchat",

    // Zsh / zinit
    "appendhistory", "atinit", "atload", "blockf", "dups", "fpath", "FPATH",
    "HISTDUP", "hookify", "SAVEHIST", "sharehistory", "shellenv",
    "zdharma", "zinit", "zicompinit", "zicdreplay", "zfunc",

    // Homebrew / Unix
    "bootout", "dscacheutil", "flushcache", "hushlogin", "keygen", "killall",
    "libexec", "linuxbrew", "nohup", "osascript", "pkill", "wslinfo",

    // macOS system commands & pmset flags
    "autopoweroff", "autorestart", "capslock", "disablesleep", "displaysleep",
    "hibernatemode", "mineffect", "MTWRFSU", "networkoversleep", "Nlsv",
    "screensharing", "setglobalstate", "setremotelogin", "setstealthmode",
    "socketfilterfw", "softwareupdate", "systemsetup", "tcpkeepalive",
    "tilesize", "trackpad", "wakeorpoweron", "womp",

    // macOS / UI / dock
    "autohide", "autogroup", "autoclean", "autofetch", "cowork",
    "recents", "startfile",

    // Windows / PowerShell
    "bbwe", "hardlink", "LASTEXITCODE", "mklink", "PROGRAMDATA",
    "pwsh", "wekyb", "winerror", "winget",

    // Linux / server
    "devtmpfs", "efivarfs", "journalctl", "tmpfs", "USERSPACE", "vcgencmd",

    // Dev tools not in built-in dicts
    "btop", "coreclr", "dotenv", "Eeuo", "freethreading", "GHCS",
    "godotcsharp", "gopls", "gsserver", "gtime", "healthcheck",
    "llst", "pathlib", "pmset", "pycache", "pydantic", "pyright", "pytest",
    "shellcheck", "typer", "venv", "worktree", "WORKTREE",

    // Common tech terms the built-in dicts miss
    "bootstrapper", "distros", "distors", "hostnames", "keepalive", "VIRTUALENV"
  ]
}
