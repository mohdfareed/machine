# EditorConfig: https://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.json]
indent_size = 2

[*.toml]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.sh]
indent_size = 2

[.{zshenv,zshrc}*]
indent_size = 2

[*.{code-snippets,code-workspace}]
indent_size = 2
